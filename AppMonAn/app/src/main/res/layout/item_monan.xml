<?xml version="1.0" encoding="utf-8"?>
<LinearLayout android:layout_height="52dp"
    android:padding="1dp"
    android:layout_width="match_parent"
    android:orientation="horizontal"
    android:background="#EBE29D"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <ImageView
        android:id="@+id/imAnhDaiDien"
        android:layout_width="50dp"
        android:background="#2196F3"
        android:layout_height="50dp">

    </ImageView>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:paddingLeft="2dp">

        <TextView
            android:id="@+id/tvTenMonAn"
            android:layout_width="match_parent"
            android:layout_height="20dp"
            android:textSize="13dp"
            android:text="Món thứ nhất"
            android:textStyle="bold"
            />
        <TextView
            android:id="@+id/tvDonGia"
            android:layout_width="match_parent"
            android:text="2000000đ"
            android:textSize="12dp"
            android:layout_height="15dp"/>

        <TextView
            android:id="@+id/tvMoTa"
            android:layout_width="match_parent"
            android:text="Nội dung mô tả"
            android:textSize="12dp"
            android:layout_height="15dp"/>
    </LinearLayout>
</LinearLayout>
